---
import '@fontsource/inter/400.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import MetaPixel from '../components/MetaPixel.astro';
import GoogleTag from '../components/GoogleTag.astro';
import type { Locale } from '../i18n/strings';

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
}

const { title, description, lang = 'tr' } = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#7c3aed" />
    <MetaPixel />
    <GoogleTag />
    <slot name="head" />
  </head>
  <body>
    <script is:inline>
      (function () {
        try {
          if (sessionStorage.getItem('s-lang-checked')) return;
          sessionStorage.setItem('s-lang-checked', '1');
          var p = location.pathname;
          if (p === '/en' || p === '/en/' || p.indexOf('/en/') === 0) return;
          var lang = (navigator.language || 'en').toLowerCase();
          if (lang === 'tr' || lang.indexOf('tr-') === 0) return;
          location.replace('/en' + p + location.search);
        } catch (e) { void e; }
      })();
    </script>
    <SiteHeader lang={lang} />
    <main>
      <slot />
    </main>
    <SiteFooter lang={lang} />
  </body>
</html>
