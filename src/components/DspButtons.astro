---
import type { Release, Track } from '../lib/types';
import { getDspLinks } from '../lib/dsp';
import IconSpotify from './icons/IconSpotify.astro';
import IconAppleMusic from './icons/IconAppleMusic.astro';
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';

interface Props {
  links: Release['data']['links'] | Track['data']['links'];
  releaseSlug: string;
  trackSlug?: string;
  lang?: Locale;
}

const { links, releaseSlug, trackSlug, lang = 'tr' } = Astro.props;
const dspLinks = getDspLinks(links);

const iconMap: Record<string, typeof IconSpotify> = {
  spotify: IconSpotify,
  appleMusic: IconAppleMusic,
};
---

{dspLinks.length > 0 && (
  <section class="dsp-section">
    <h2 class="dsp-heading">{t(lang, 'dsp.heading')}</h2>
    <p class="dsp-cta">{t(lang, 'dsp.cta')}</p>
    <div class="dsp-buttons">
      {dspLinks.map((dsp) => {
        const Icon = iconMap[dsp.key];
        const isPrimary = dsp.key === 'spotify';
        return (
          <a
            href={dsp.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`dsp-btn${isPrimary ? ' dsp-btn--primary' : ''}`}
            data-dsp={dsp.key}
            data-release-slug={releaseSlug}
            data-track-slug={trackSlug}
            data-lang={lang}
          >
            {Icon && <Icon size={isPrimary ? 24 : 20} />}
            <span>{dsp.label}</span>
          </a>
        );
      })}
    </div>
  </section>
)}

<script>
  import { track } from '../lib/tracking';

  document.addEventListener('click', (e) => {
    const anchor = (e.target as HTMLElement).closest<HTMLAnchorElement>('a[data-dsp]');
    if (!anchor) return;
    const dsp = anchor.dataset.dsp;
    const releaseSlug = anchor.dataset.releaseSlug;
    const trackSlug = anchor.dataset.trackSlug;
    const lang = anchor.dataset.lang;
    if (dsp && releaseSlug) {
      track({ name: 'ClickDsp', params: { dsp, releaseSlug, trackSlug: trackSlug || undefined, lang: lang || undefined } });
    }
  });
</script>
