---
import type { Release, Track } from '../lib/types';
import { getDspLinks } from '../lib/dsp';

interface Props {
  links: Release['data']['links'] | Track['data']['links'];
  releaseSlug: string;
  trackSlug?: string;
}

const { links, releaseSlug, trackSlug } = Astro.props;
const dspLinks = getDspLinks(links);
---

{dspLinks.length > 0 && (
  <div class="dsp-buttons">
    {dspLinks.map((dsp) => (
      <a
        href={dsp.url}
        target="_blank"
        rel="noopener noreferrer"
        class="dsp-btn"
        data-dsp={dsp.key}
        data-release-slug={releaseSlug}
        data-track-slug={trackSlug}
      >
        {dsp.label}
      </a>
    ))}
  </div>
)}

<script>
  import { track } from '../lib/tracking';

  document.addEventListener('click', (e) => {
    const anchor = (e.target as HTMLElement).closest<HTMLAnchorElement>('a[data-dsp]');
    if (!anchor) return;
    const dsp = anchor.dataset.dsp;
    const releaseSlug = anchor.dataset.releaseSlug;
    const trackSlug = anchor.dataset.trackSlug;
    if (dsp && releaseSlug) {
      track({ name: 'ClickDsp', params: { dsp, releaseSlug, trackSlug: trackSlug || undefined } });
    }
  });
</script>
