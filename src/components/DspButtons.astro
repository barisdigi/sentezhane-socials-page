---
import type { Release, Track } from '../lib/types';
import { getDspLinks } from '../lib/dsp';
import IconSpotify from './icons/IconSpotify.astro';
import IconAppleMusic from './icons/IconAppleMusic.astro';
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';

interface Props {
  links: Release['data']['links'] | Track['data']['links'];
  releaseSlug: string;
  trackSlug?: string;
  lang?: Locale;
}

const { links, releaseSlug, trackSlug, lang = 'tr' } = Astro.props;
const dspLinks = getDspLinks(links);

const iconMap: Record<string, typeof IconSpotify> = {
  spotify: IconSpotify,
  appleMusic: IconAppleMusic,
};
---

{dspLinks.length > 0 && (
  <section class="dsp-section">
    <div class="dsp-buttons">
      {dspLinks.map((dsp) => {
        const Icon = iconMap[dsp.key];
        const isPrimary = dsp.key === 'spotify';
        const label = dsp.key === 'spotify'
          ? t(lang, 'dsp.listenOn.spotify')
          : t(lang, 'dsp.listenOn.appleMusic');
        return (
          <a
            href={dsp.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`dsp-btn${isPrimary ? ' dsp-btn--primary' : ''}`}
            data-dsp={dsp.key}
            data-release-slug={releaseSlug}
            data-track-slug={trackSlug}
            data-lang={lang}
          >
            {Icon && <Icon size={isPrimary ? 24 : 20} />}
            <span>{label}</span>
            {isPrimary && <span class="dsp-btn__sparkle" aria-hidden="true"></span>}
          </a>
        );
      })}
    </div>
  </section>
)}

<script>
  import { track } from '../lib/tracking';
  import { detectPlatform, isMobile } from '../lib/platform';
  import { getNativeDeepLink } from '../lib/dsp';

  type DspKey = 'spotify' | 'appleMusic';

  const platform = detectPlatform();

  // iOS users see Apple Music as the primary CTA; reorder the inline buttons
  // and swap the visual "primary" treatment accordingly.
  if (platform === 'ios') {
    document.querySelectorAll<HTMLElement>('.dsp-buttons').forEach((container) => {
      const apple = container.querySelector<HTMLElement>('a[data-dsp="appleMusic"]');
      const spotify = container.querySelector<HTMLElement>('a[data-dsp="spotify"]');
      if (!apple || !spotify) return;
      container.insertBefore(apple, spotify);
      apple.classList.add('dsp-btn--primary');
      spotify.classList.remove('dsp-btn--primary');
      const sparkle = spotify.querySelector('.dsp-btn__sparkle');
      if (sparkle) apple.appendChild(sparkle);
    });
  }

  // On mobile, rewrite https DSP URLs to their native app schemes (only
  // where the platform actually has a registered handler) so the installed
  // app handles the link instead of the in-app webview / browser.
  if (isMobile(platform)) {
    document.querySelectorAll<HTMLAnchorElement>('a[data-dsp]').forEach((a) => {
      const key = a.dataset.dsp as DspKey | undefined;
      if (!key) return;
      const deepLink = getNativeDeepLink(key, a.href, platform);
      if (deepLink !== a.href) a.href = deepLink;
    });
  }

  document.addEventListener('click', (e) => {
    const anchor = (e.target as HTMLElement).closest<HTMLAnchorElement>('a[data-dsp]');
    if (!anchor) return;
    if (anchor.dataset.sticky === '1') return; // sticky bar emits its own event
    const dsp = anchor.dataset.dsp;
    const releaseSlug = anchor.dataset.releaseSlug;
    const trackSlug = anchor.dataset.trackSlug;
    const lang = anchor.dataset.lang;
    if (dsp && releaseSlug) {
      track({ name: 'ClickDsp', params: { dsp, releaseSlug, trackSlug: trackSlug || undefined, lang: lang || undefined } });
    }
  });
</script>
