---
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
---

<div class="filter-chips">
  <button class="chip" data-filter="all" aria-pressed="true">{t(lang, 'filter.all')}</button>
  <button class="chip" data-filter="album" aria-pressed="false">{t(lang, 'filter.albums')}</button>
  <button class="chip" data-filter="single" aria-pressed="false">{t(lang, 'filter.singles')}</button>
</div>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip[data-filter]');
  const grid = document.querySelector<HTMLElement>('.release-grid');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.setAttribute('aria-pressed', 'false'));
      chip.setAttribute('aria-pressed', 'true');
      const filter = chip.dataset.filter!;
      if (filter === 'all') {
        delete grid!.dataset.filter;
      } else {
        grid!.dataset.filter = filter;
      }
    });
  });
</script>
