---
import { getEntry } from 'astro:content';
import type { Locale } from '../i18n/strings';
import { localizedPath } from '../i18n/strings';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
const artist = await getEntry('artist', 'artist');
const name = artist?.data.name ?? 'Sentezhane';

const homeHref = localizedPath(lang, '/');
---

<header class="site-header">
  <a href={homeHref} class="site-header__logo">{name}</a>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    padding-block: 0.75rem;
    padding-inline: var(--content-padding);
    background: rgba(10, 10, 12, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .site-header__logo {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--fg);
    text-decoration: none;
  }

  .site-header__logo:hover {
    text-decoration: none;
    color: var(--accent);
  }
</style>
