---
import { getEntry } from 'astro:content';
import type { Locale } from '../i18n/strings';
import { t, localizedPath, stripLocalePrefix } from '../i18n/strings';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
const artist = await getEntry('artist', 'artist');
const name = artist?.data.name ?? 'Sentezhane';

const basePath = stripLocalePrefix(Astro.url.pathname);
const trHref = localizedPath('tr', basePath);
const enHref = localizedPath('en', basePath);
const homeHref = localizedPath(lang, '/');
---

<header class="site-header">
  <a href={homeHref} class="site-header__logo">{name}</a>
  <nav class="lang-switch" aria-label="Language">
    <a href={trHref} aria-current={lang === 'tr' ? 'true' : undefined}>{t(lang, 'lang.tr')}</a>
    <a href={enHref} aria-current={lang === 'en' ? 'true' : undefined}>{t(lang, 'lang.en')}</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    padding-block: 0.75rem;
    padding-inline: var(--content-padding);
    background: rgba(10, 10, 12, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .site-header__logo {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--fg);
    text-decoration: none;
  }

  .site-header__logo:hover {
    text-decoration: none;
    color: var(--accent);
  }
</style>
