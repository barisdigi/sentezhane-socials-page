---
import type { Locale } from '../i18n/strings';

interface Props {
  videoId: string;
  title?: string;
  releaseSlug: string;
  trackSlug?: string;
  lang?: Locale;
}

const { videoId, title = 'YouTube video player', releaseSlug, trackSlug, lang = 'tr' } = Astro.props;
const posterUrl = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
---

<div
  class="youtube-embed"
  data-video-id={videoId}
  data-release-slug={releaseSlug}
  data-track-slug={trackSlug}
  data-title={title}
  data-lang={lang}
>
  <button
    type="button"
    class="youtube-embed__poster"
    style={`background-image: url('${posterUrl}')`}
    aria-label={title}
  >
    <span class="youtube-embed__play" aria-hidden="true">
      <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
    </span>
  </button>
</div>

<script>
  import { track } from '../lib/tracking';

  interface YTPlayerEvent {
    target: { getIframe: () => HTMLIFrameElement };
    data: number;
  }

  interface YTPlayerOptions {
    videoId: string;
    host: string;
    playerVars: Record<string, unknown>;
    events: {
      onReady: (event: YTPlayerEvent) => void;
      onStateChange: (event: YTPlayerEvent) => void;
    };
  }

  interface YTStatic {
    Player: new (el: HTMLElement, opts: YTPlayerOptions) => unknown;
    PlayerState: { PLAYING: number };
  }

  function getYT(): YTStatic {
    return (window as unknown as { YT: YTStatic }).YT;
  }

  function ensureApi(cb: () => void) {
    if (getYT()?.Player) {
      cb();
      return;
    }
    const w = window as unknown as { onYouTubeIframeAPIReady?: () => void };
    const prev = w.onYouTubeIframeAPIReady;
    w.onYouTubeIframeAPIReady = () => {
      if (prev) prev();
      cb();
    };
    if (!document.querySelector('script[src*="youtube.com/iframe_api"]')) {
      const tag = document.createElement('script');
      tag.src = 'https://www.youtube.com/iframe_api';
      document.head.appendChild(tag);
    }
  }

  function loadPlayer(container: HTMLElement) {
    if (container.dataset.initialized) return;
    container.dataset.initialized = '1';

    const videoId = container.dataset.videoId!;
    const releaseSlug = container.dataset.releaseSlug!;
    const trackSlug = container.dataset.trackSlug || undefined;
    const title = container.dataset.title || 'YouTube video player';
    const lang = (container.dataset.lang as 'tr' | 'en') || 'tr';

    container.innerHTML = '';
    const mount = document.createElement('div');
    container.appendChild(mount);

    ensureApi(() => {
      const YT = getYT();
      new YT.Player(mount, {
        videoId,
        host: 'https://www.youtube-nocookie.com',
        playerVars: { rel: 0, modestbranding: 1, autoplay: 1 },
        events: {
          onReady: (event: YTPlayerEvent) => {
            event.target.getIframe().title = title;
          },
          onStateChange: (event: YTPlayerEvent) => {
            if (event.data === getYT().PlayerState.PLAYING) {
              const iframe = event.target.getIframe();
              if (!iframe || iframe.dataset.fired) return;
              iframe.dataset.fired = '1';
              track({ name: 'VideoPlay', params: { releaseSlug, trackSlug, lang } });
            }
          },
        },
      });
    });
  }

  document.addEventListener('click', (e) => {
    const poster = (e.target as HTMLElement).closest<HTMLElement>('.youtube-embed__poster');
    if (!poster) return;
    const container = poster.closest<HTMLElement>('.youtube-embed[data-video-id]');
    if (!container) return;
    loadPlayer(container);
  });
</script>
