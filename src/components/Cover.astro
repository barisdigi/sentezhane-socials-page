---
/**
 * Renders a cover image as a <picture> with responsive WebP variants
 * generated by scripts/optimize-covers.mjs. Falls back to the original
 * PNG (public/covers/<name>.png) when the source isn't a known cover.
 *
 * Variants live at /covers/optimized/<name>-{240,320,480,640,960}.webp
 */

interface Props {
  src: string;
  alt: string;
  width?: number;
  loading?: 'lazy' | 'eager';
  priority?: boolean;
  sizes?: string;
}

const {
  src,
  alt,
  width = 480,
  loading: loadingProp,
  priority,
  sizes = '(max-width: 480px) 50vw, (max-width: 768px) 240px, 320px',
} = Astro.props;

const loading = priority ? 'eager' : (loadingProp ?? 'lazy');
const fetchpriority = priority ? 'high' : undefined;

const VARIANT_WIDTHS = [240, 320, 480, 640, 960];

// Detect /covers/<name>.png so we can swap in optimized WebP variants.
const match = src.match(/^\/covers\/([^/]+)\.png$/i);
const optimized = match
  ? {
      base: `/covers/optimized/${match[1]}`,
      srcset: VARIANT_WIDTHS.map((w) => `/covers/optimized/${match[1]}-${w}.webp ${w}w`).join(', '),
    }
  : null;

// Pick a sensible default raster src so the <img> fallback isn't the giant PNG.
const fallbackSrc = optimized ? `${optimized.base}-${width <= 320 ? 480 : 640}.webp` : src;
---

{optimized ? (
  <picture>
    <source type="image/webp" srcset={optimized.srcset} sizes={sizes} />
    <img
      src={fallbackSrc}
      alt={alt}
      width={width}
      height={width}
      loading={loading}
      decoding="async"
      fetchpriority={fetchpriority}
      class="cover"
    />
  </picture>
) : (
  <img
    src={src}
    alt={alt}
    width={width}
    height={width}
    loading={loading}
    decoding="async"
    fetchpriority={fetchpriority}
    sizes={sizes}
    class="cover"
  />
)}
