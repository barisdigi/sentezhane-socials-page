---
import { SHARE_NETWORKS, buildShareUrl } from '../lib/share';
import IconX from './icons/IconX.astro';
import IconWhatsApp from './icons/IconWhatsApp.astro';
import IconFacebook from './icons/IconFacebook.astro';
import IconCopy from './icons/IconCopy.astro';
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';

interface Props {
  url: string;
  title: string;
  releaseSlug: string;
  trackSlug?: string;
  lang?: Locale;
}

const { url, title, releaseSlug, trackSlug, lang = 'tr' } = Astro.props;
const text = `${title} — Sentezhane`;

const networkLabels: Record<string, string> = {
  x: 'X',
  whatsapp: 'WhatsApp',
  facebook: 'Facebook',
};

const networkIcons: Record<string, typeof IconX> = {
  x: IconX,
  whatsapp: IconWhatsApp,
  facebook: IconFacebook,
};
---

<h2 class="share-heading">{t(lang, 'share.heading')}</h2>
<div class="share-buttons" data-release-slug={releaseSlug} data-track-slug={trackSlug ?? ''} data-share-url={url} data-share-text={text} data-lang={lang} data-label-copy={t(lang, 'share.copy')} data-label-copied={t(lang, 'share.copied')}>
  {SHARE_NETWORKS.map((network) => {
    const Icon = networkIcons[network];
    return (
      <a class="share-btn" data-share-network={network} href={buildShareUrl(network, { url, text })} target="_blank" rel="noopener noreferrer">
        {Icon && <Icon size={16} />}
        <span>{networkLabels[network]}</span>
      </a>
    );
  })}
  <button type="button" class="share-btn" data-share-network="copy">
    <IconCopy size={16} />
    <span>{t(lang, 'share.copy')}</span>
  </button>
</div>

<script>
  import { track } from '../lib/tracking';

  document.addEventListener('click', (event) => {
    const el = (event.target as HTMLElement).closest<HTMLElement>('[data-share-network]');
    if (!el) return;

    const container = el.closest<HTMLElement>('.share-buttons');
    if (!container) return;

    const network = el.dataset.shareNetwork!;
    const releaseSlug = container.dataset.releaseSlug!;
    const trackSlug = container.dataset.trackSlug || undefined;
    const shareUrl = container.dataset.shareUrl!;
    const lang = container.dataset.lang || undefined;

    track({ name: 'Share', params: { network, releaseSlug, trackSlug, lang } });

    if (network === 'copy') {
      event.preventDefault();
      if (navigator.clipboard) {
        navigator.clipboard.writeText(shareUrl);
      }
      const labelCopy = container.dataset.labelCopy || 'Linki Kopyala';
      const labelCopied = container.dataset.labelCopied || 'Kopyalandı';
      const span = el.querySelector('span');
      if (span) {
        span.textContent = labelCopied;
        setTimeout(() => { span.textContent = labelCopy; }, 2000);
      }
    }
  });
</script>
