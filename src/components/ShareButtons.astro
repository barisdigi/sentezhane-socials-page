---
import { SHARE_NETWORKS, buildShareUrl } from '../lib/share';

interface Props {
  url: string;
  title: string;
  releaseSlug: string;
  trackSlug?: string;
}

const { url, title, releaseSlug, trackSlug } = Astro.props;
const text = `${title} — Sentezhane`;

const networkLabels: Record<string, string> = {
  x: 'X',
  whatsapp: 'WhatsApp',
  facebook: 'Facebook',
};
---

<h2 class="share-heading">Paylaş</h2>
<div class="share-buttons" data-release-slug={releaseSlug} data-track-slug={trackSlug ?? ''} data-share-url={url} data-share-text={text}>
  {SHARE_NETWORKS.map((network) => (
    <a class="share-btn" data-share-network={network} href={buildShareUrl(network, { url, text })} target="_blank" rel="noopener noreferrer">
      {networkLabels[network]}
    </a>
  ))}
  <button type="button" class="share-btn" data-share-network="copy">Linki Kopyala</button>
</div>

<script>
  import { track } from '../lib/tracking';

  document.addEventListener('click', (event) => {
    const el = (event.target as HTMLElement).closest<HTMLElement>('[data-share-network]');
    if (!el) return;

    const container = el.closest<HTMLElement>('.share-buttons');
    if (!container) return;

    const network = el.dataset.shareNetwork!;
    const releaseSlug = container.dataset.releaseSlug!;
    const trackSlug = container.dataset.trackSlug || undefined;
    const shareUrl = container.dataset.shareUrl!;

    track({ name: 'Share', params: { network, releaseSlug, trackSlug } });

    if (network === 'copy') {
      event.preventDefault();
      if (navigator.clipboard) {
        navigator.clipboard.writeText(shareUrl);
      }
      const original = el.textContent;
      el.textContent = 'Kopyalandı';
      setTimeout(() => {
        el.textContent = original;
      }, 2000);
    }
  });
</script>
