---
import Cover from './Cover.astro';
import type { Locale } from '../i18n/strings';
import { t, localizedPath } from '../i18n/strings';

interface Props {
  slug: string;
  title: string;
  type: 'album' | 'single';
  cover?: string;
  trackCount?: number;
  lang?: Locale;
}

const { slug, title, type, cover, trackCount, lang = 'tr' } = Astro.props;
const typeLabel = t(lang, `release.type.${type}`);
const metaLine = type === 'album' && trackCount ? `${typeLabel} · ${t(lang, 'release.tracks.count', { count: trackCount })}` : typeLabel;
const href = localizedPath(lang, `/${slug}/`);
---

<a class="release-card" href={href} data-type={type}>
  {cover && (
    <Cover
      src={cover}
      alt={title}
      width={240}
      sizes="(max-width: 360px) 100vw, (max-width: 480px) 50vw, 14rem"
    />
  )}
  <div class="release-card__body">
    <h3>{title}</h3>
    <span class="release-card__type">{metaLine}</span>
  </div>
</a>
