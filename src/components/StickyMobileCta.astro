---
import type { Release, Track } from '../lib/types';
import { getDspLinks } from '../lib/dsp';
import IconSpotify from './icons/IconSpotify.astro';
import IconAppleMusic from './icons/IconAppleMusic.astro';
import type { Locale } from '../i18n/strings';
import { t } from '../i18n/strings';

interface Props {
  links: Release['data']['links'] | Track['data']['links'];
  releaseSlug: string;
  trackSlug?: string;
  lang?: Locale;
}

const { links, releaseSlug, trackSlug, lang = 'tr' } = Astro.props;
const dspLinks = getDspLinks(links);
const iconMap: Record<string, typeof IconSpotify> = {
  spotify: IconSpotify,
  appleMusic: IconAppleMusic,
};
const labelFor = (key: string) =>
  key === 'spotify'
    ? t(lang, 'dsp.listenOn.spotify')
    : key === 'appleMusic'
      ? t(lang, 'dsp.listenOn.appleMusic')
      : t(lang, 'dsp.cta');
---

{dspLinks.length > 0 && (
  <div class="sticky-cta" data-sticky-cta aria-hidden="true">
    {dspLinks.map((dsp, i) => {
      const Icon = iconMap[dsp.key];
      return (
        <a
          href={dsp.url}
          target="_blank"
          rel="noopener noreferrer"
          class="sticky-cta__btn"
          data-dsp={dsp.key}
          data-release-slug={releaseSlug}
          data-track-slug={trackSlug}
          data-lang={lang}
          data-sticky="1"
          data-sticky-slot={dsp.key}
          hidden={i !== 0}
        >
          {Icon && <Icon size={22} />}
          <span>{labelFor(dsp.key)}</span>
          <span class="sticky-cta__sparkle" aria-hidden="true"></span>
        </a>
      );
    })}
  </div>
)}

<script>
  import { track } from '../lib/tracking';
  import { detectPlatform, isMobile } from '../lib/platform';
  import { getNativeDeepLink } from '../lib/dsp';

  type DspKey = 'spotify' | 'appleMusic';

  const bar = document.querySelector<HTMLElement>('[data-sticky-cta]');

  if (bar) {
    const platform = detectPlatform();

    // Pick the preferred DSP for this platform. iOS → Apple Music if present,
    // otherwise fall back to whatever is already visible (Spotify by default).
    const preferredKey: DspKey = platform === 'ios' ? 'appleMusic' : 'spotify';
    const slots = Array.from(bar.querySelectorAll<HTMLElement>('[data-sticky-slot]'));
    const preferred = slots.find((el) => el.dataset.stickySlot === preferredKey);
    if (preferred) {
      slots.forEach((el) => {
        el.hidden = el !== preferred;
      });
    }

    // Rewrite to native app schemes on mobile so installed apps capture the tap.
    if (isMobile(platform)) {
      bar.querySelectorAll<HTMLAnchorElement>('a[data-dsp]').forEach((a) => {
        const key = a.dataset.dsp as DspKey | undefined;
        if (!key) return;
        const deepLink = getNativeDeepLink(key, a.href);
        if (deepLink !== a.href) a.href = deepLink;
      });
    }

    const setVisible = (visible: boolean) => {
      bar.classList.toggle('is-visible', visible);
      bar.setAttribute('aria-hidden', visible ? 'false' : 'true');
    };

    // Observe the inline primary CTA so the sticky bar only appears once the
    // user has scrolled past it. After iOS reorder, the primary may have
    // changed; re-query at this point.
    const inline = document.querySelector<HTMLElement>('.dsp-btn--primary');
    if (inline && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            setVisible(!entry.isIntersecting);
          }
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0 },
      );
      io.observe(inline);
    } else {
      setVisible(true);
    }

    bar.addEventListener('click', (e) => {
      const a = (e.target as HTMLElement).closest<HTMLAnchorElement>('a[data-dsp]');
      if (!a) return;
      const dsp = a.dataset.dsp;
      const releaseSlug = a.dataset.releaseSlug;
      const trackSlug = a.dataset.trackSlug;
      const lang = a.dataset.lang;
      if (dsp && releaseSlug) {
        track({
          name: 'ClickDsp',
          params: {
            dsp,
            releaseSlug,
            trackSlug: trackSlug || undefined,
            lang: lang || undefined,
            placement: 'sticky',
          },
        });
      }
    });
  }
</script>
