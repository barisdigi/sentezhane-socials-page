---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import profile from '../assets/profile.png';
import { normalizeBioText } from '../lib/format';
import IconWebsite from './icons/IconWebsite.astro';
import IconInstagram from './icons/IconInstagram.astro';
import IconYouTube from './icons/IconYouTube.astro';
import IconTikTok from './icons/IconTikTok.astro';
import IconX from './icons/IconX.astro';
import type { Locale } from '../i18n/strings';

interface Props {
  lang?: Locale;
}

const { lang = 'tr' } = Astro.props;
const artist = await getEntry('artist', 'artist');

const platformLabels: Record<string, string> = {
  website: 'Website',
  instagram: 'Instagram',
  youtube: 'YouTube',
  tiktok: 'TikTok',
  twitter: 'X',
};

const platformIcons: Record<string, typeof IconWebsite> = {
  website: IconWebsite,
  instagram: IconInstagram,
  youtube: IconYouTube,
  tiktok: IconTikTok,
  twitter: IconX,
};

const order = ['website', 'instagram', 'youtube', 'tiktok', 'twitter'] as const;
---

{artist && (
  <section class="artist-bio">
    <Image src={profile} alt={artist.data.name} width={120} height={120} class="artist-bio__avatar" />
    <h2>{artist.data.name}</h2>
    {(() => {
      const bioText = lang === 'en' ? (artist.data.bioEn ?? artist.data.bio) : artist.data.bio;
      return bioText ? <p>{normalizeBioText(bioText)}</p> : null;
    })()}
    <nav class="artist-bio__links">
      {order.map((key) => {
        const url = artist.data.socials[key];
        const Icon = platformIcons[key];
        return url ? (
          <a href={url} target="_blank" rel="noopener noreferrer">
            {Icon && <Icon size={18} />}
            <span>{platformLabels[key]}</span>
          </a>
        ) : null;
      })}
    </nav>
  </section>
)}
