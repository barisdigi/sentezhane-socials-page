---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { getAllReleases, getTracksForAlbum, getTrack } from '../../lib/releases';
import { displayTitle } from '../../lib/format';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Cover from '../../components/Cover.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import DspButtons from '../../components/DspButtons.astro';
import StickyMobileCta from '../../components/StickyMobileCta.astro';
// import YouTubeEmbed from '../../components/YouTubeEmbed.astro'; // disabled: re-enable to restore YouTube embed
import SeoMeta from '../../components/SeoMeta.astro';
import JsonLd from '../../components/JsonLd.astro';
import { buildMusicRecordingJsonLd, abs } from '../../lib/seo';
import ShareButtons from '../../components/ShareButtons.astro';
import { t, localizedPath } from '../../i18n/strings';

const lang = 'tr' as const;

export const getStaticPaths: GetStaticPaths = async () => {
  const releases = await getAllReleases();
  const albums = releases.filter((r) => r.data.type === 'album');
  const paths = [];
  for (const album of albums) {
    const tracks = await getTracksForAlbum(album.data.slug);
    for (const track of tracks) {
      paths.push({ params: { album: album.data.slug, track: track.data.slug } });
    }
  }
  return paths;
};

const { album: albumSlug, track: trackSlug } = Astro.params;
const result = await getTrack(String(albumSlug), String(trackSlug));
if (!result) throw new Error('Not found');

const { track, album, resolvedCover } = result;

const trackTitle = displayTitle(track.data);
const albumTitle = displayTitle(album.data);

const artistEntry = await getCollection('artist');
const artistName = artistEntry[0]?.data.name ?? 'Sentezhane';

const canonical = '/' + album.data.slug + '/' + track.data.slug + '/';
const alternates = [
  { hreflang: 'tr', href: abs(canonical) },
  { hreflang: 'en', href: abs(localizedPath('en', canonical)) },
  { hreflang: 'x-default', href: abs(canonical) },
];

const jsonLdData = buildMusicRecordingJsonLd({
  recording: {
    title: trackTitle,
    slug: track.data.slug,
    cover: resolvedCover,
    albumSlug: album.data.slug,
    albumTitle,
  },
  artistName,
});
---

<BaseLayout title={`${trackTitle} — ${albumTitle}`} lang={lang}>
  <SeoMeta slot="head" title={`${trackTitle} — ${albumTitle}`} canonical={canonical} image={resolvedCover} ogType="music.song" lang={lang} alternates={alternates} />
  <JsonLd slot="head" data={jsonLdData} />
  <article class="release">
    <Breadcrumb items={[
      { label: artistName, href: '/' },
      { label: albumTitle, href: `/${album.data.slug}/` },
      { label: trackTitle },
    ]} />

    <div class="release__grid">
      <div class="release__cover">
        {resolvedCover && (
          <Cover src={resolvedCover} alt={trackTitle} width={320} priority />
        )}
      </div>

      <div class="release__content">
        <header>
          <h1>{trackTitle}</h1>
          <p class="release-meta">{t(lang, 'release.album.label')}: <a href={`/${album.data.slug}/`}>{albumTitle}</a></p>
        </header>

        <DspButtons links={track.data.links} releaseSlug={album.data.slug} trackSlug={track.data.slug} lang={lang} />

        {/* YouTube embed disabled — re-enable to restore
        {track.data.youtubeVideoId && (
          <YouTubeEmbed videoId={track.data.youtubeVideoId} title={trackTitle} releaseSlug={album.data.slug} trackSlug={track.data.slug} lang="tr" />
        )}
        */}

        <ShareButtons url={abs('/' + album.data.slug + '/' + track.data.slug + '/')} title={trackTitle} releaseSlug={album.data.slug} trackSlug={track.data.slug} lang={lang} />
      </div>
    </div>
  </article>
  <StickyMobileCta links={track.data.links} releaseSlug={album.data.slug} trackSlug={track.data.slug} lang={lang} />
</BaseLayout>
