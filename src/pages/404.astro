---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Sayfa Bulunamadı">
  <meta slot="head" name="robots" content="noindex" />
  <section class="not-found">
    <h1>404</h1>
    <p>Aradığın sayfa burada değil.</p>
    <a href="/" class="dsp-btn">Diskografiye Dön</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem var(--content-padding);
  }
  .not-found h1 {
    font-size: 5rem;
    margin: 0;
    color: var(--accent);
  }
  .not-found p {
    font-size: 1.25rem;
    color: var(--fg-muted);
    margin: 1rem 0 2rem;
  }
</style>
