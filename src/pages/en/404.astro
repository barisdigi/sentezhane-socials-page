---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/strings';

const lang = 'en' as const;
---

<BaseLayout title={t(lang, '404.title')} lang={lang}>
  <meta slot="head" name="robots" content="noindex" />
  <section class="not-found">
    <h1>{t(lang, '404.heading')}</h1>
    <p>{t(lang, '404.message')}</p>
    <a href="/en/" class="dsp-btn">{t(lang, '404.back')}</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem var(--content-padding);
  }
  .not-found h1 {
    font-size: 5rem;
    margin: 0;
    color: var(--accent);
  }
  .not-found p {
    font-size: 1.25rem;
    color: var(--fg-muted);
    margin: 1rem 0 2rem;
  }
</style>
