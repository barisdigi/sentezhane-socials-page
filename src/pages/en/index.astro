---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FilterChips from '../../components/FilterChips.astro';
import ReleaseGrid from '../../components/ReleaseGrid.astro';
import ArtistBio from '../../components/ArtistBio.astro';
import SeoMeta from '../../components/SeoMeta.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getAllReleases, getReleaseTrackCounts } from '../../lib/releases';
import { buildMusicGroupJsonLd, abs } from '../../lib/seo';
import { t } from '../../i18n/strings';

const lang = 'en' as const;
const releases = await getAllReleases();
const trackCounts = await getReleaseTrackCounts();
const artistEntries = await getCollection('artist');
const artist = artistEntries[0];

const alternates = [
  { hreflang: 'tr', href: abs('/') },
  { hreflang: 'en', href: abs('/en/') },
  { hreflang: 'x-default', href: abs('/') },
];
---

<BaseLayout title="Sentezhane" lang={lang}>
  <SeoMeta slot="head" title={`Sentezhane — ${t(lang, 'home.subtitle')}`} canonical="/en/" ogType="website" lang={lang} alternates={alternates} />
  <JsonLd slot="head" data={buildMusicGroupJsonLd(artist.data, 'en')} />

  <section class="hero">
    <h1>Sentezhane</h1>
    <p class="hero-sub">{t(lang, 'home.subtitle')}</p>
  </section>

  <div class="filter-chips--center">
    <FilterChips lang={lang} />
  </div>
  <ReleaseGrid releases={releases} trackCounts={trackCounts} lang={lang} />
  <ArtistBio lang={lang} />
</BaseLayout>
