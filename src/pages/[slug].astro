---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { getAllReleases, getReleaseBySlug, getTracksForAlbum } from '../lib/releases';
import { displayTitle } from '../lib/format';
import BaseLayout from '../layouts/BaseLayout.astro';
import Cover from '../components/Cover.astro';
import DspButtons from '../components/DspButtons.astro';
import StickyMobileCta from '../components/StickyMobileCta.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import TrackList from '../components/TrackList.astro';
import SeoMeta from '../components/SeoMeta.astro';
import JsonLd from '../components/JsonLd.astro';
import { buildMusicAlbumJsonLd, buildMusicRecordingJsonLd, abs } from '../lib/seo';
import ShareButtons from '../components/ShareButtons.astro';
import { t, localizedPath } from '../i18n/strings';

const lang = 'tr' as const;

export const getStaticPaths: GetStaticPaths = async () => {
  const releases = await getAllReleases();
  return releases.map((r) => ({ params: { slug: r.data.slug } }));
};

const { slug } = Astro.params;
const release = await getReleaseBySlug(String(slug));
if (!release) throw new Error('Not found');

const tracks = release.data.type === 'album' ? await getTracksForAlbum(String(slug)) : [];

const title = displayTitle(release.data);
const typeLabel = t(lang, `release.type.${release.data.type}`);
const formattedDate = release.data.releaseDate
  ? new Intl.DateTimeFormat('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date(release.data.releaseDate))
  : undefined;

const artistEntries = await getCollection('artist');
const artistName = artistEntries[0]?.data.name ?? 'Sentezhane';

const canonical = '/' + release.data.slug + '/';
const ogType = release.data.type === 'album' ? 'music.album' : 'music.song';

const alternates = [
  { hreflang: 'tr', href: abs(canonical) },
  { hreflang: 'en', href: abs(localizedPath('en', canonical)) },
  { hreflang: 'x-default', href: abs(canonical) },
];

const jsonLdData = release.data.type === 'album'
  ? buildMusicAlbumJsonLd({
      album: release.data,
      tracks: tracks.map((t) => ({ title: displayTitle(t.data), slug: t.data.slug })),
      artistName,
    })
  : buildMusicRecordingJsonLd({
      recording: { title, slug: release.data.slug, cover: release.data.cover },
      artistName,
    });
---

<BaseLayout title={title} lang={lang}>
  <SeoMeta slot="head" title={title} canonical={canonical} image={release.data.cover} ogType={ogType} lang={lang} alternates={alternates} />
  <JsonLd slot="head" data={jsonLdData} />
  <article class="release">
    <div class="release__cover">
      {release.data.cover && (
        <Cover src={release.data.cover} alt={title} width={320} priority />
      )}
    </div>

    <div class="release__content">
      <header>
        <h1>{title}</h1>
        <span class="release-type">{typeLabel}</span>
        {formattedDate && <p class="release-meta">{formattedDate}</p>}
      </header>

      <DspButtons links={release.data.links} releaseSlug={release.data.slug} lang={lang} />

      {release.data.youtubeVideoId && (
        <YouTubeEmbed videoId={release.data.youtubeVideoId} title={title} releaseSlug={release.data.slug} lang="tr" />
      )}

      {release.data.type === 'album' && tracks.length > 0 && (
        <>
          <ShareButtons url={abs('/' + release.data.slug + '/')} title={title} releaseSlug={release.data.slug} lang={lang} />
          <h2>{t(lang, 'release.tracks.heading')}</h2>
          <TrackList albumSlug={release.data.slug} tracks={tracks} lang={lang} />
        </>
      )}

      {release.data.type !== 'album' && (
        <ShareButtons url={abs('/' + release.data.slug + '/')} title={title} releaseSlug={release.data.slug} lang={lang} />
      )}
    </div>
  </article>
  <StickyMobileCta links={release.data.links} releaseSlug={release.data.slug} lang={lang} />
</BaseLayout>
